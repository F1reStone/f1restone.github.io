---
/**
 * Badge Component
 * Displays a small status indicator or label with proper icon spacing
 */
import type { HTMLAttributes } from 'astro/types';
import { cn } from '@/lib/cn';
import { badgeVariants } from './badge.variants';

interface Props extends HTMLAttributes<'span'>, HTMLAttributes<'a'> {
  variant?: 'default' | 'success' | 'warning' | 'error' | 'info' | 'brand';
  size?: 'sm' | 'md';
  pulse?: boolean;
  pill?: boolean;
  href?: string;
}

const { variant = 'default', size = 'md', pulse = false, pill = false, href, class: className, ...attrs } = Astro.props;

const Element = href ? 'a' : 'span';

// FireStone: [Dynamically apply hover color & STRONGER glow ONLY if the badge is an active link]
const interactiveClasses = href ? {
  default: 'hover:text-foreground hover:drop-shadow-[0_0_12px_currentColor]',
  success: 'hover:brightness-125 hover:drop-shadow-[0_0_12px_currentColor]',
  warning: 'hover:brightness-125 hover:drop-shadow-[0_0_12px_currentColor]',
  error: 'hover:brightness-125 hover:drop-shadow-[0_0_12px_currentColor]',
  info: 'hover:brightness-125 hover:drop-shadow-[0_0_12px_currentColor]',
  brand: 'hover:text-brand-500 dark:hover:text-brand-300 hover:drop-shadow-[0_0_12px_currentColor]',
}[variant] : '';
---

<Element href={href} class={cn(badgeVariants({ variant, size, pill }), interactiveClasses, className)} {...attrs}>
  {pulse && (
    <span class="relative flex h-2 w-2 shrink-0" aria-hidden="true">
      <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-current opacity-75" />
      <span class="relative inline-flex h-2 w-2 rounded-full bg-current" />
    </span>
  )}
  <slot />
</Element>