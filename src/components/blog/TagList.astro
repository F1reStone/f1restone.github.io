---
/**
 * Horizontal list of tag chips that link to permalink tag archive pages
 */
import { tagToSlug } from '@/lib/blog';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';

interface Props {
  tags: string[];
  active?: string;
  class?: string;
}

const { tags, active, class: extraClass } = Astro.props;
---

{tags.length > 0 && (
  <ul class:list={['flex flex-wrap items-center gap-1.5', extraClass]} aria-label="Browse by tag">
    {tags.map((tag, index) => {
      const isActive = active === tag;
      return (
        <>
          {index > 0 && <li class="h-0.5 w-0.5 rounded-full bg-border-strong shrink-0" aria-hidden="true" />}
          <li>
            <Badge
              href={`/blog/tag/${tagToSlug(tag)}`}
              variant={isActive ? 'default' : 'brand'}
              aria-current={isActive ? 'page' : undefined}
              class={isActive ? 'drop-shadow-[0_0_12px_currentColor] text-foreground' : ''} 
            >
              #{tag}
            </Badge>
          </li>
        </>
      );
    })}
  </ul>
)}