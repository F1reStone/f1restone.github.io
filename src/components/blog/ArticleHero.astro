---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { formatDate } from '@/lib/utils';
import Logo from '@/components/ui/marketing/Logo/Logo.astro';
import BlogImageSVG from '@/components/blog/BlogImageSVG.astro';

interface Props {
  title: string;
  description: string;
  publishedAt: Date;
  updatedAt?: Date;
  author?: string;
  tags?: string[];
  image?: ImageMetadata;
  imageAlt?: string;
  svgSlug?: string;
}

const {
  title,
  description,
  publishedAt,
  updatedAt,
  author = 'Team',
  tags = [],
  image,
  imageAlt,
  svgSlug,
} = Astro.props;

// Estimate reading time
const wordsPerMinute = 200;
const estimatedWords = description.split(' ').length * 15;
const readingTime = Math.max(1, Math.ceil(estimatedWords / wordsPerMinute));
---

<!-- FireStone: [Immersive Article Hero with cover background, blur, and invert-section] -->
<header class="relative isolate overflow-hidden min-h-[70svh] flex flex-col justify-center invert-section border-b border-white/10">
  
  <!-- Background Image Layer -->
  <div class="absolute inset-0 -z-20 w-full h-full bg-[#080C13]">
    {svgSlug ? (
      <div class="w-full h-full opacity-80 [&>svg]:w-full [&>svg]:h-full [&>svg]:object-cover" style="color: var(--color-brand-500);">
        <BlogImageSVG slug={svgSlug} title={imageAlt || title} />
      </div>
    ) : image ? (
      <Image
        src={image}
        alt={imageAlt || title}
        widths={[640, 960, 1280, 1920]}
        sizes="100vw"
        class="w-full h-full object-cover opacity-80"
        loading="eager"
      />
    ) : null}
  </div>

  <!-- Dimming & Blur Overlay (压低亮度并做毛玻璃处理，保证白字绝对清晰) -->
  <div class="absolute inset-0 -z-10 bg-black/50 backdrop-blur-lg mix-blend-multiply"></div>

  <!-- Content Container -->
  <div class="relative z-10 mx-auto w-full max-w-8xl px-6 pt-24 pb-16">
    <div class="max-w-4xl animate-hero-stagger">
      <!-- Tags -->
      {tags.length > 0 && (
        <div class="mb-[var(--space-heading-gap)] flex flex-wrap gap-2">
          {tags.map((tag) => (
            <span class="inline-flex items-center rounded-full bg-brand-100 dark:bg-brand-900/30 px-3 py-1 text-xs font-semibold text-white ring-1 ring-inset ring-white/20 backdrop-blur-md shadow-sm">
              {tag}
            </span>
          ))}
        </div>
      )}

      <!-- Title (复用主页的 hero-title-text 实现金属高光和变粗交互) -->
      <h1 class="hero-title-wrapper !text-[clamp(2.5rem,6vw,4.5rem)] sm:!text-5xl md:!text-6xl tracking-tight z-10 relative mb-6">
        <span class="hero-title-text">{title}</span>
      </h1>

      <!-- Description -->
      <p class="hero-description-text text-xl leading-relaxed max-w-2xl mb-[var(--space-stack-lg)]">
        {description}
      </p>

      <!-- Meta info -->
      <div class="flex flex-wrap items-center gap-[var(--space-stack-lg)] text-sm text-foreground-muted">
        <!-- Author -->
        <div class="flex items-center gap-3">
          <Logo size="sm" letter={author.charAt(0).toUpperCase()} />
          <p class="font-semibold text-foreground">{author}</p>
        </div>

        <div class="h-8 w-px bg-white/20 hidden md:block"></div>

        <!-- Published date -->
        <div class="flex items-center gap-2">
          <svg class="h-5 w-5 text-foreground-subtle" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
          </svg>
          <time datetime={publishedAt.toISOString()}>
            {formatDate(publishedAt)}
          </time>
        </div>

        {updatedAt && (
          <>
            <div class="h-8 w-px bg-white/20 hidden md:block"></div>
            <div class="flex items-center gap-2">
              <svg class="h-5 w-5 text-foreground-subtle" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99" />
              </svg>
              <time datetime={updatedAt.toISOString()}>
                更新于 {formatDate(updatedAt)}
              </time>
            </div>
          </>
        )}

        <div class="h-8 w-px bg-white/20 hidden md:block"></div>

        <!-- Reading time -->
        <div class="flex items-center gap-2">
          <svg class="h-5 w-5 text-foreground-subtle" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span>预计阅读时间 {readingTime} 分钟</span>
        </div>
      </div>
    </div>
  </div>
</header>