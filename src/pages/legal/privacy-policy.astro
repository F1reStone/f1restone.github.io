---
import LegalLayout from '@/layouts/LegalLayout.astro';
import { loadLegalPage } from '@/lib/legal';

const { entry, Content, headings } = await loadLegalPage('zh-CN', 'privacy-policy');
---

<LegalLayout
  title={entry.data.title}
  titleEn={entry.data.titleEn}
  description={entry.data.description}
  updatedAt={entry.data.updatedAt}
  headings={headings}
  sectionLabel="法律信息"
  backHref="/legal"
  backLabel="返回法律信息"
>
  <Content />
</LegalLayout>