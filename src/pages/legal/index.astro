---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Hero } from '@/components/hero';
import Header from '@/components/layout/Header.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Footer from '@/components/layout/Footer.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import siteConfig from '@/config/site.config';

const legalPages = [
  {
    title: '隐私政策',
    description: '说明我们如何收集、使用、保存和保护你的信息。',
    href: '/legal/privacy-policy',
  },
  {
    title: '服务条款',
    description: '说明您在访问和使用本网站时适用的基本规则。',
    href: '/legal/terms-of-service',
  },
];
---

<BaseLayout
  title="法律信息"
  description="查看本网站的隐私政策、服务条款与相关说明。"
>
  <Header
    slot="header"
    position="fixed"
    shape="bar"
    variant="transparent"
    size="lg"
    showCta={false}
    maxWidth="8xl"
  />

  <main class="min-h-screen">
  <Hero layout="split" size="xl" class="hero-dark-gradient invert-section" showScrollIndicator>
    <Badge slot="badge" variant="brand" pill>
      <Icon name="shield-check" size="sm" />
      法律信息
    </Badge>
    
    <h1 slot="title" class="hero-title-wrapper !text-[clamp(2.5rem,12vw,4rem)] sm:!text-6xl md:!text-7xl lg:!text-8xl tracking-tight z-10 relative">
      <span class="hero-title-text">Legal Information</span>
    </h1>

    <p slot="description" class="hero-description-text">与 FireStone 网站相关的法律信息。</p>
  </Hero>

    <section class="pb-[var(--space-section-md)]">
      <div class="mx-auto grid max-w-8xl gap-6 px-6 md:grid-cols-2">
        {legalPages.map((page) => (
          <a
            href={page.href}
            class="group rounded-2xl border border-border bg-background p-6 shadow-sm transition-all hover:-translate-y-0.5 hover:border-brand-500"
          >
            <div class="flex items-start justify-between gap-4">
              <div>
                <h2 class="font-display text-2xl font-semibold text-foreground">
                  {page.title}
                </h2>
                <p class="mt-3 text-foreground-muted">
                  {page.description}
                </p>
              </div>

              <span class="rounded-full border border-border bg-background-secondary p-3 text-foreground-muted transition-colors group-hover:text-brand-500">
                <Icon name="arrow-up-right" size="sm" />
              </span>
            </div>
          </a>
        ))}
      </div>
    </section>
  </main>

  <Footer
    slot="footer"
    layout="columns"
    background="secondary"
  />
</BaseLayout>